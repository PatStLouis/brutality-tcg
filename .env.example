# ============================================================
# WEB SERVICE (apps/web) — owns the database and ledger keys
# ============================================================

# Public URL of the web app (used in redemption links and OAuth redirects)
BASE_URL=http://localhost:3000

# SQLite database location (relative paths resolve from the repo root).
# Only the web service touches the database.
DATABASE_PATH=./data/brutality.db

# Secret used to sign browser session cookies (generate a long random string)
SESSION_SECRET=change-me

# Discord OAuth application (web sign-in for the binder)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Shared secret the bot must present to the internal API
# (same value on both services; generate a long random string)
BOT_API_SECRET=change-me-too

# Demo mode: enables guest login (Discord bypass) and in-browser pack
# redemption. NEVER set this on a production deployment.
DEMO=false

# ============================================================
# BOT SERVICE (apps/bot) — no database access
# ============================================================

# Discord bot token
DISCORD_BOT_TOKEN=

# Where the web service's internal API lives
WEB_API_URL=http://localhost:3000

# BOT_API_SECRET=  (same value as the web service, see above)

# Comma-separated role IDs that are allowed to redeem. Leave empty to allow
# any member who has pack credits.
ELIGIBLE_ROLE_IDS=
# Comma-separated channel IDs where !redeem is accepted. Leave empty to allow
# any channel the bot can read.
REDEEM_CHANNEL_IDS=
